{% set N = N | int -%}
{% set GS = (GS | default(4)) | int -%}
{% set NG = ((N - 1) // GS) + 1 -%}
{#- CLA carry expression macro.
    Produces: g[base+k-1] | (p[base+k-1] & g[base+k-2]) | ...
    If cin is nonempty, appends: | (p[base+k-1] & ... & p[base] & cin)
-#}
{%- macro cla_carry(g, p, base, k, cin) -%}
{{ g }}{{ base + k - 1 }}
{%- for t in range(1, k) %} | (
{%- for m in range(t) %}{{ p }}{{ base + k - 1 - m }} & {% endfor %}
{{- g }}{{ base + k - 1 - t }})
{%- endfor %}
{%- if cin %} | (
{%- for m in range(k) %}{{ p }}{{ base + k - 1 - m }} & {% endfor %}
{{- cin }})
{%- endif %}
{%- endmacro -%}

module adder_{{ N }}_bit (
    input  wire [{{ N-1 }}:0] a,
    input  wire [{{ N-1 }}:0] b,
    output wire [{{ N }}:0] sum
);
    // Per-bit generate and propagate signals
{%- for i in range(N) %}
    wire cl_g{{ i }}; assign cl_g{{ i }} = a[{{ i }}] & b[{{ i }}];
{%- endfor %}

{%- for i in range(N) %}
    wire cl_p{{ i }}; assign cl_p{{ i }} = a[{{ i }}] ^ b[{{ i }}];
{%- endfor %}

{%- for grp in range(NG) %}
{%- set base = grp * GS %}
{%- set gs = [GS, N - base] | min %}
{%- if grp == 0 %}
{%- set cin = "" %}
{%- else %}
{%- set cin = "cl_CGin" ~ grp %}
{%- endif %}

    // Group {{ grp }} (bits {{ base }}{% if gs > 1 %}-{{ base + gs - 1 }}{% endif %})
{%- if grp > 0 %}
    wire cl_CGin{{ grp }}; assign cl_CGin{{ grp }} = {{ cla_carry("cl_GG", "cl_PP", 0, grp, "") }};
{%- endif %}
{%- for k in range(1, gs) %}
    wire cl_c{{ base + k }}; assign cl_c{{ base + k }} = {{ cla_carry("cl_g", "cl_p", base, k, cin) }};
{%- endfor %}
    wire cl_GG{{ grp }}; assign cl_GG{{ grp }} = {{ cla_carry("cl_g", "cl_p", base, gs, "") }};
{%- if grp > 0 %}
    wire cl_PP{{ grp }}; assign cl_PP{{ grp }} = {% for m in range(gs) %}{% if m > 0 %} & {% endif %}cl_p{{ base + gs - 1 - m }}{% endfor %};
{%- endif %}
{%- endfor %}

    // Carry out
    wire cl_c{{ N }}; assign cl_c{{ N }} = {{ cla_carry("cl_GG", "cl_PP", 0, NG, "") }};

    // Sum bits
{%- for i in range(N) %}
{%- if i == 0 %}
    wire cl_s{{ i }}; assign cl_s{{ i }} = cl_p{{ i }};
{%- elif i % GS == 0 %}
    wire cl_s{{ i }}; assign cl_s{{ i }} = cl_p{{ i }} ^ cl_CGin{{ i // GS }};
{%- else %}
    wire cl_s{{ i }}; assign cl_s{{ i }} = cl_p{{ i }} ^ cl_c{{ i }};
{%- endif %}
{%- endfor %}

    assign sum = {cl_c{{ N }}{% for i in range(N-1, -1, -1) %}, cl_s{{ i }}{% endfor %}};
endmodule
