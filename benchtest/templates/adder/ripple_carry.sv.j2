{% set N = N | int -%}
module adder_{{ N }}_bit (
    input  wire [{{ N-1 }}:0] a,
    input  wire [{{ N-1 }}:0] b,
    output wire [{{ N }}:0] sum
);
    // Bit 0 (Half Adder)
    wire rc_s0; assign rc_s0 = a[0] ^ b[0];
    wire rc_c0; assign rc_c0 = a[0] & b[0];

    {% for i in range(1, N) -%}
    // Bit {{ i }}
    wire rc_s{{ i }}; assign rc_s{{ i }} = a[{{ i }}] ^ b[{{ i }}] ^ rc_c{{ i-1 }};
    wire rc_c{{ i }}; assign rc_c{{ i }} = (a[{{ i }}] & b[{{ i }}]) | (a[{{ i }}] & rc_c{{ i-1 }}) | (b[{{ i }}] & rc_c{{ i-1 }});
    {% endfor %}

    assign sum = {rc_c{{ N-1 }}, {% for i in range(N-1, -1, -1) %}rc_s{{ i }}{{ ", " if not loop.last }}{% endfor %}};

endmodule
